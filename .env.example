# Copy to .env and edit for your environment
PROJECT_NAME=ShelfLife
DATABASE_URL=sqlite:///./shelflife.db

# JWT — generate a strong secret in production: openssl rand -hex 32
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Bootstrap admin (created by `python -m app.seed`)
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=admin123
